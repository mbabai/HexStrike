{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "outDir": "public/generated",
    "rootDir": "src",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmitOnError": false
  },
  "include": ["src/shared/**/*"]
}
